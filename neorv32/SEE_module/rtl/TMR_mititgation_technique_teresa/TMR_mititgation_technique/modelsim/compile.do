#==============================================================================
# File: compile.do
#
# Description:
#   Compiles all RTL and testbench files into the ModelSim work library.
#
# Usage:
#   do compile.do
#
#==============================================================================


echo "--------------------------------------------"
echo "Compiling TMR on Register"
echo "--------------------------------------------"


#------------------------------------------------------------------------------
# Create work library
#------------------------------------------------------------------------------

if {[file exists work]} {
    vdel -lib work -all
}

vlib work
vmap work work


#------------------------------------------------------------------------------
# Compile RTL files 
#------------------------------------------------------------------------------

echo "Compiling RTL..."

vcom -2008 ../src/tmr_register.vhd


#------------------------------------------------------------------------------
# Compile Testbench files
#------------------------------------------------------------------------------

echo "Compiling Testbench..."

vcom -2008 ../tb/tb_tmr_register.vhd


echo "--------------------------------------------"
echo "Compilation finished"
echo "--------------------------------------------"